---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"div">;

const { class: className, ...rest } = Astro.props;
---

<div
	class:list={[
		"mx-auto max-w-7xl px-6 sm:px-8 lg:px-0",
		"sm:grid sm:grid-cols-6 lg:grid-cols-12 gap-6",
		className,
	]}
	{...rest}
>
	<slot />
</div>
