---
import { Image } from "astro:assets";
import logo from "../../assets/logo.png";
import { socials } from "../../data/nav";
import Container from "./Container.astro";
import Section from "./Section.astro";
import SocialLink from "../ui/SocialLink.astro";

const year = new Date().getFullYear();
---

<Section class="bg-ink text-white py-12">
	<Container>
		<div class="col-start-2 col-end-12 flex flex-col md:flex-row md:items-center md:justify-between gap-8">
			<div class="flex flex-col gap-3">
				<p class="flex items-center gap-2 font-bold text-lg">
					<Image src={logo} width={32} height={32} alt="" />
					<span>LAXMAN KC</span>
				</p>
				<span class="text-sm text-white/60">© {year} Laxman KC. All rights reserved.</span>
			</div>

			<div class="flex items-center gap-1">
				{
					socials.map((s) => (
						<SocialLink platform={s.platform} href={s.href} label={s.label} />
					))
				}
			</div>

			<p class="text-sm text-white/60">
				Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-white hover:text-primary transition-colors">Astro</a>
			</p>
		</div>
	</Container>
</Section>
