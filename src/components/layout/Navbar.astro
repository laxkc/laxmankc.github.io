---
import { Image } from "astro:assets";
import Download from "@lucide/astro/icons/download";
import logo from "../../assets/logo.png";
import { navLinks } from "../../data/nav";
import Container from "./Container.astro";
---

<header class="sticky top-0 z-50 w-full bg-ink text-white">
	<Container class="!py-0">
		<div class="col-start-2 col-end-12 flex items-center justify-between h-16">
			<a href={import.meta.env.BASE_URL} class="flex items-center gap-2 font-bold text-lg">
				<Image src={logo} width={32} height={32} alt="" />
				<span>LAXMAN KC</span>
			</a>

			<nav class="hidden md:flex items-center gap-8">
				{
					navLinks.map((link) => (
						<a
							href={link.href}
							data-nav-link={link.href.replace("#", "")}
							class="group relative text-sm text-white/80 hover:text-primary transition-colors data-[active=true]:text-white"
						>
							{link.label}
							<span
								aria-hidden="true"
								class="absolute -bottom-1.5 left-0 right-0 h-0.5 rounded-full bg-primary opacity-0 transition-opacity duration-150 group-data-[active=true]:opacity-100"
							/>
						</a>
					))
				}
			</nav>

			<a
				href={`${import.meta.env.BASE_URL}laxman_kc_cv.pdf`}
				target="_blank"
				rel="noopener"
				class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-white text-white hover:bg-white hover:text-ink transition-colors"
			>
				<Download size={16} aria-hidden="true" />
				Resume
			</a>
		</div>
	</Container>
</header>

<script>
	const THRESHOLD = 96;

	const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));
	const pairs = links
		.map((link) => {
			const id = link.dataset.navLink ?? "";
			const section = document.getElementById(id);
			return section ? { link, section, id } : null;
		})
		.filter((p): p is { link: HTMLAnchorElement; section: HTMLElement; id: string } => p !== null);

	const setActive = (id: string | null) => {
		for (const { link } of pairs) {
			const isActive = link.dataset.navLink === id;
			link.dataset.active = isActive ? "true" : "false";
			if (isActive) link.setAttribute("aria-current", "true");
			else link.removeAttribute("aria-current");
		}
	};

	const compute = () => {
		let activeId: string | null = null;
		for (const { section, id } of pairs) {
			if (section.getBoundingClientRect().top <= THRESHOLD) activeId = id;
			else break;
		}
		setActive(activeId);
	};

	let frame = 0;
	const schedule = () => {
		if (frame) return;
		frame = requestAnimationFrame(() => {
			frame = 0;
			compute();
		});
	};

	for (const { link, id } of pairs) {
		link.addEventListener("click", () => setActive(id));
	}

	window.addEventListener("scroll", schedule, { passive: true });
	window.addEventListener("resize", schedule);
	compute();
</script>
