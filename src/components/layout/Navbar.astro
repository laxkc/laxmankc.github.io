---
import { Image } from "astro:assets";
import Download from "@lucide/astro/icons/download";
import Menu from "@lucide/astro/icons/menu";
import logo from "../../assets/logo.png";
import { navLinks, spySections } from "../../data/nav";
import Container from "./Container.astro";
---

<header class="sticky top-0 z-50 w-full bg-ink text-white">
	<div
		data-scroll-progress
		class="absolute top-0 left-0 h-0.5 w-full bg-primary origin-left"
		style="transform: scaleX(0);"
		aria-hidden="true"
	>
	</div>
	<Container class="!py-0">
		<div class="col-start-2 col-end-12 flex items-center justify-between h-16">
			<a href={import.meta.env.BASE_URL} class="flex items-center gap-2 font-bold text-lg">
				<Image src={logo} width={32} height={32} alt="" />
				<span>LAXMAN KC</span>
			</a>

			<nav class="hidden md:flex items-center gap-8">
				{
					navLinks.map((link) => (
						<a
							href={link.href}
							data-nav-link={link.href.replace("#", "")}
							class="group relative text-sm text-white/80 hover:text-primary transition-colors data-[active=true]:text-white"
						>
							{link.label}
							<span
								aria-hidden="true"
								class="absolute -bottom-1.5 left-0 right-0 h-0.5 rounded-full bg-primary opacity-0 transition-opacity duration-150 group-data-[active=true]:opacity-100"
							/>
						</a>
					))
				}
			</nav>

			<div class="flex items-center gap-2">
				<details class="md:hidden relative" data-mobile-menu>
					<summary
						class="list-none cursor-pointer p-2 rounded-md hover:bg-white/10 transition-colors"
						aria-label="Toggle menu"
					>
						<Menu size={20} aria-hidden="true" />
					</summary>
					<nav
						class="absolute right-0 top-full mt-2 w-48 rounded-lg bg-ink border border-white/10 shadow-lg p-2 z-50"
					>
						{
							navLinks.map((link) => (
								<a
									href={link.href}
									class="block px-3 py-2 text-sm text-white/80 hover:text-primary hover:bg-white/5 rounded transition-colors"
								>
									{link.label}
								</a>
							))
						}
					</nav>
				</details>

				<a
					href={`${import.meta.env.BASE_URL}laxman_kc_cv.pdf`}
					target="_blank"
					rel="noopener"
					class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg border border-white text-white hover:bg-white hover:text-ink transition-colors"
				>
					<Download size={16} aria-hidden="true" />
					Resume
				</a>
			</div>
		</div>
	</Container>
</header>

<script>
	import { spySections } from "../../data/nav";

	const THRESHOLD = 96;

	const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));
	const navLinkIds = new Set(links.map((l) => l.dataset.navLink));

	// Track every section in spySections, even if it's not shown in the nav.
	const trackedSections = spySections
		.map((id) => {
			const section = document.getElementById(id);
			return section ? { id, section } : null;
		})
		.filter((s): s is { id: string; section: HTMLElement } => s !== null);

	const setActive = (id: string | null) => {
		for (const link of links) {
			const isActive = link.dataset.navLink === id;
			link.dataset.active = isActive ? "true" : "false";
			if (isActive) link.setAttribute("aria-current", "true");
			else link.removeAttribute("aria-current");
		}
	};

	const compute = () => {
		// Find the last section whose top has crossed the threshold line.
		let currentId: string | null = null;
		for (const { id, section } of trackedSections) {
			if (section.getBoundingClientRect().top <= THRESHOLD) currentId = id;
			else break;
		}
		// Highlight only if the current section also has a nav link.
		setActive(currentId && navLinkIds.has(currentId) ? currentId : null);
	};

	let frame = 0;
	const schedule = () => {
		if (frame) return;
		frame = requestAnimationFrame(() => {
			frame = 0;
			compute();
		});
	};

	for (const link of links) {
		const id = link.dataset.navLink;
		if (id) link.addEventListener("click", () => setActive(id));
	}

	window.addEventListener("scroll", schedule, { passive: true });
	window.addEventListener("resize", schedule);
	compute();

	// Close mobile menu when a link inside is clicked
	document.querySelectorAll<HTMLDetailsElement>("[data-mobile-menu]").forEach((d) => {
		d.querySelectorAll("a").forEach((a) => {
			a.addEventListener("click", () => d.removeAttribute("open"));
		});
	});

	// Scroll progress indicator
	import("motion").then(({ scroll }) => {
		const bar = document.querySelector<HTMLElement>("[data-scroll-progress]");
		if (bar) {
			scroll((progress: number) => {
				bar.style.transform = `scaleX(${progress})`;
			});
		}
	});
</script>
