---
import Dot from "@lucide/astro/icons/dot";
import GraduationCap from "@lucide/astro/icons/graduation-cap";
import type { EducationEntry } from "../../data/education";

type Props = EducationEntry;

const { type, title, institution, location, period, bullets } = Astro.props;
---

<article
	class="rounded-2xl border-2 border-ink/15 shadow-md bg-white p-6 lg:p-8"
>
	<GraduationCap size={24} class="text-primary" />

	<p class="mt-4 text-xs font-semibold tracking-wider text-secondary uppercase">
		{type}
	</p>
	<h3 class="mt-2 text-2xl font-semibold leading-tight">{title}</h3>

	<p class="mt-3 text-sm text-secondary">
		{institution}<br />
		{location}
	</p>

	<p class="mt-3 text-sm font-medium text-primary">{period}</p>

	<ul class="mt-5 space-y-2">
		{
			bullets.map((b) => (
				<li class="flex gap-1 text-base text-ink/80">
					<Dot
						aria-hidden="true"
						size={20}
						class="text-ink/40 shrink-0 mt-0.5"
					/>
					<span>{b}</span>
				</li>
			))
		}
	</ul>
</article>
