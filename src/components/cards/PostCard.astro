---
interface Props {
	title: string;
	date: Date;
	excerpt: string;
	readTime: string;
	href?: string;
}

const { title, date, excerpt, readTime, href } = Astro.props;
const Wrapper = href ? "a" : "article";
const formatted = date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<Wrapper
	href={href}
	class="group flex flex-col gap-3 p-6 rounded-2xl border border-white/10 hover:border-white/30 transition-colors"
>
	<div class="flex items-center gap-3 text-xs text-white/60">
		<time datetime={date.toISOString()}>{formatted}</time>
		<span aria-hidden="true">·</span>
		<span>{readTime}</span>
	</div>
	<h3 class="text-2xl font-semibold leading-tight group-hover:underline underline-offset-4">{title}</h3>
	<p class="text-base text-white/70">{excerpt}</p>
</Wrapper>
