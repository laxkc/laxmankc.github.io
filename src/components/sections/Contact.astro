---
import Container from "../layout/Container.astro";
import Section from "../layout/Section.astro";
import SocialLink from "../ui/SocialLink.astro";
import { socials } from "../../data/nav";

const email = socials.find((s) => s.platform === "email");
const emailAddress = "laxk4025@gmail.com";
---

<Section id="contact" class="bg-primary text-white py-32 lg:py-48">
	<Container>
		<div class="col-start-2 col-end-12 lg:col-start-3 lg:col-end-11 text-center">
			<h2 class="text-5xl md:text-6xl font-extrabold tracking-tight">Let's build something.</h2>
			<p class="mt-6 text-xl text-white/80 max-w-xl mx-auto">
				I'm open to interesting work and conversation. The fastest way to reach me is email.
			</p>
			{
				email && (
					<div class="mt-10 flex justify-center">
						<a
							href={email.href}
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center px-8 py-4 text-lg font-semibold rounded-lg bg-white text-primary hover:bg-white/90 transition-colors"
						>
							{emailAddress}
						</a>
					</div>
				)
			}
			<div class="mt-10 flex justify-center gap-2">
				{
					socials
						.filter((s) => s.platform !== "email")
						.map((s) => <SocialLink platform={s.platform} href={s.href} label={s.label} />)
				}
			</div>
		</div>
	</Container>
</Section>
