---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import MessageCircle from "@lucide/astro/icons/message-circle";
import Container from "../layout/Container.astro";
import Section from "../layout/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="bg-ink text-white py-32 lg:py-48">
  <Container>
    <div
      class="col-start-2 col-end-12 flex flex-col items-center lg:flex-row lg:items-center gap-12 lg:gap-16"
    >
      <div class="lg:basis-1/2">
        <!-- <p class="text-sm font-medium text-white/60 mb-6">Hi, I'm Laxman —</p> -->
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight"
        >
          Software Engineer, System <span class="text-primary">Designer</span> and
          <span class="text-primary">Builder</span>
        </h1>
        <p class="mt-8 text-xl text-white/70 max-w-2xl">
          I design and build software with a focus on performance, and long-term
          maintainability.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <Button href="#work" size="lg" class="min-w-56">
            View my work
            <ArrowRight size={18} aria-hidden="true" />
          </Button>
          <Button href="#thinking" size="lg" variant="ghostOnDark" class="min-w-56">
            Let's connect
            <MessageCircle size={18} aria-hidden="true" />
          </Button>
        </div>
      </div>

      <div class="lg:basis-1/2 w-full max-w-md lg:max-w-none mx-auto flex items-center justify-center">
        <img
          src={`${import.meta.env.BASE_URL}hero-section.png`}
          alt=""
          width="1000"
          height="500"
          class="w-full h-auto max-h-full object-contain"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </Container>
</Section>
