---
import ArrowRight from "@lucide/astro/icons/arrow-right";
import { getCollection } from "astro:content";
import Container from "../layout/Container.astro";
import Section from "../layout/Section.astro";
import WorkCard from "../cards/WorkCard.astro";

const work = (await getCollection("work", ({ data }) => data.featured))
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 4);
---

<Section id="work" class="py-24 lg:py-32">
	<Container>
		<div class="col-start-2 col-end-12">
			<div class="flex items-baseline justify-between gap-4 mb-4">
				<h2 class="text-4xl md:text-5xl font-bold">Selected work</h2>
				<a
					href="https://github.com/laxkc?tab=repositories"
					target="_blank"
					rel="noopener noreferrer"
					class="group inline-flex items-center gap-2 text-primary font-medium hover:gap-3 transition-all shrink-0"
				>
					View all projects
					<ArrowRight size={18} aria-hidden="true" class="transition-transform group-hover:translate-x-1" />
				</a>
			</div>

			<p class="text-lg text-secondary max-w-2xl mb-12">
				A selection of systems I've designed and built.
			</p>

			<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
				{
					work.map((item) => (
						<WorkCard
							title={item.data.title}
							description={item.data.summary}
							cover={item.data.cover}
							tags={item.data.tags}
							href={item.data.href ?? `/work/${item.id}`}
						/>
					))
				}
			</div>
		</div>
	</Container>
</Section>
