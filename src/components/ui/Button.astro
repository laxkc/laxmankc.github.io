---
import type { HTMLAttributes } from "astro/types";

type Variant = "primary" | "ghost" | "ghostOnDark" | "link";
type Size = "md" | "lg";

interface BaseProps {
	variant?: Variant;
	size?: Size;
	class?: string;
}

type Props = BaseProps &
	(
		| ({ href: string } & Omit<HTMLAttributes<"a">, keyof BaseProps>)
		| ({ href?: undefined } & Omit<HTMLAttributes<"button">, keyof BaseProps>)
	);

const { variant = "primary", size = "md", href, class: className, ...rest } = Astro.props;

const base =
	"inline-flex items-center justify-center gap-2 font-medium rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary";

const sizes: Record<Size, string> = {
	md: "px-5 py-2.5 text-base",
	lg: "px-6 py-3 text-lg",
};

const variants: Record<Variant, string> = {
	primary: "bg-primary text-white hover:bg-primary/90",
	ghost: "border-2 border-primary text-ink hover:bg-primary/5",
	ghostOnDark: "border-2 border-primary text-white hover:bg-primary/10",
	link: "text-primary underline underline-offset-4 hover:no-underline px-0 py-0",
};

const classes = [base, variant !== "link" && sizes[size], variants[variant], className]
	.filter(Boolean)
	.join(" ");
---

{
	href ? (
		<a href={href} class={classes} {...(rest as HTMLAttributes<"a">)}>
			<slot />
		</a>
	) : (
		<button class={classes} {...(rest as HTMLAttributes<"button">)}>
			<slot />
		</button>
	)
}
