---
import Mail from "@lucide/astro/icons/mail";
import type { SocialPlatform } from "../../data/nav";

interface Props {
	platform: SocialPlatform;
	href: string;
	label: string;
	class?: string;
}

const { platform, href, label, class: className } = Astro.props;
---

<a
	href={href}
	aria-label={label}
	class:list={[
		"inline-flex items-center justify-center w-10 h-10 rounded-md text-current opacity-80 hover:opacity-100 hover:bg-current/10 transition-all",
		className,
	]}
	target={href.startsWith("http") ? "_blank" : undefined}
	rel={href.startsWith("http") ? "noopener noreferrer" : undefined}
>
	{
		platform === "github" && (
			<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="pointer-events-none">
				<path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.53-2.55-.29-5.24-1.27-5.24-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.96 10.96 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.69 5.36-5.25 5.65.41.36.78 1.06.78 2.13v3.16c0 .31.21.68.8.56 4.56-1.52 7.85-5.83 7.85-10.91C23.5 5.65 18.35.5 12 .5Z" />
			</svg>
		)
	}
	{
		platform === "linkedin" && (
			<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="pointer-events-none">
				<path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.65-1.85 3.4-1.85 3.63 0 4.3 2.39 4.3 5.5v6.24ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.22 0Z" />
			</svg>
		)
	}
	{platform === "email" && <Mail size={20} aria-hidden="true" class="pointer-events-none" />}
</a>
